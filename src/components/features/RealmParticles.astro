---
// 粒子背景效果 — 通过 data-realm 自动切换极昼/霁梦粒子
---

<div class="realm-particles" aria-hidden="true"></div>

<style is:global>
  .realm-particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: var(--particle-bg, url('/assets/light-particle.svg'));
    background-repeat: repeat;
    background-size: clamp(120px, 15vw, 200px) clamp(120px, 15vw, 200px);
    opacity: var(--realm-particle-opacity, 0.6);
    transition: background-image 0.6s ease-in-out, opacity 0.6s ease-in-out;
  }
</style>
