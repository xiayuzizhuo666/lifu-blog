---
// 丽芙定制光标拖尾 — 极昼鎏金 / 霁梦银蓝
---

<style is:global>
  #lifu-cursor-dot {
    position: fixed; top: 0; left: 0; z-index: 99999;
    width: 5px; height: 5px; pointer-events: none;
    border-radius: 50%;
    background: rgba(var(--lifu-cursor-accent, 212,168,83), 0.5);
    box-shadow: 0 0 8px rgba(var(--lifu-cursor-accent, 212,168,83), 0.4);
    transform: translate(-50%, -50%);
    will-change: transform;
    transition: background 0.8s cubic-bezier(0.45, 0, 0.55, 1),
                box-shadow 0.8s cubic-bezier(0.45, 0, 0.55, 1);
    opacity: 0;
  }
  #lifu-cursor-dot.visible { opacity: 1; }

  :root { --lifu-cursor-accent: 212, 168, 83; }
  .dark { --lifu-cursor-accent: 126, 174, 228; }

  @media (hover: none), (pointer: coarse) {
    #lifu-cursor-dot { display: none !important; }
  }
</style>

<div aria-hidden="true"><div id="lifu-cursor-dot"></div></div>

<script is:inline>
  (function() {
    if (window.matchMedia('(pointer: coarse)').matches || window.matchMedia('(hover: none)').matches) return;

    var dot, mouseX = 0, mouseY = 0, curX = 0, curY = 0, raf = 0, active = false;
    var findDot = function() { return document.getElementById('lifu-cursor-dot'); };

    function onEnter() { active = true; dot = findDot(); if (dot) dot.classList.add('visible'); }
    function onLeave() { active = false; if (dot) dot.classList.remove('visible'); }
    function onMove(e) { mouseX = e.clientX; mouseY = e.clientY; }

    function loop() {
      dot = findDot();
      if (active && dot) {
        curX += (mouseX - curX) * 0.08;
        curY += (mouseY - curY) * 0.08;
        dot.style.transform = 'translate3d(' + Math.round(curX) + 'px, ' + Math.round(curY) + 'px, 0)';
      }
      raf = requestAnimationFrame(loop);
    }

    document.addEventListener('mouseenter', onEnter);
    document.addEventListener('mouseleave', onLeave);
    document.addEventListener('mousemove', onMove, { passive: true });
    raf = requestAnimationFrame(loop);
  })();
</script>
