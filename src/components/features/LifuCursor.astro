---
// 丽芙定制光标 — 极昼鎏金 / 霁梦银蓝 双形态
---

<style is:global>
  /* 隐藏默认光标 */
  html.custom-cursor,
  html.custom-cursor * {
    cursor: none !important;
  }
  html.custom-cursor a,
  html.custom-cursor button,
  html.custom-cursor [role="button"],
  html.custom-cursor input,
  html.custom-cursor textarea,
  html.custom-cursor select,
  html.custom-cursor [data-cursor="pointer"] {
    cursor: none !important;
  }
  html.custom-cursor input[type="text"],
  html.custom-cursor textarea,
  html.custom-cursor [data-cursor="text"] {
    cursor: none !important;
  }

  /* 光标主体 */
  #lifu-cursor {
    position: fixed;
    top: 0; left: 0;
    width: 20px; height: 20px;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    transition: width 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                height 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                border-color 0.8s cubic-bezier(0.45, 0, 0.55, 1);
    will-change: transform, width, height;
    mix-blend-mode: difference;
  }
  #lifu-cursor::before {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.9);
    transition: inset 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                border-radius 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                background 0.25s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  #lifu-cursor::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1.5px solid rgba(var(--lifu-cursor-accent, 212,168,83), 0.8);
    border-radius: 3px;
    transition: border-color 0.8s cubic-bezier(0.45, 0, 0.55, 1),
                border-radius 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                box-shadow 0.25s cubic-bezier(0.22, 0.61, 0.36, 1);
    box-shadow: 0 0 8px rgba(var(--lifu-cursor-accent, 212,168,83), 0.4),
                0 0 20px rgba(var(--lifu-cursor-accent, 212,168,83), 0.1);
  }

  /* hover 状态 */
  #lifu-cursor.lifu-cursor-hover {
    width: 40px; height: 40px;
  }
  #lifu-cursor.lifu-cursor-hover::before {
    inset: 8px;
    background: rgba(255,255,255,0.3);
  }
  #lifu-cursor.lifu-cursor-hover::after {
    border-radius: 50%;
    box-shadow: 0 0 16px rgba(var(--lifu-cursor-accent, 212,168,83), 0.6),
                0 0 40px rgba(var(--lifu-cursor-accent, 212,168,83), 0.2);
  }

  /* 文本选择状态 */
  #lifu-cursor.lifu-cursor-text {
    width: 3px; height: 1.2em;
    border-radius: 1.5px;
  }
  #lifu-cursor.lifu-cursor-text::before {
    inset: 0;
    border-radius: 1.5px;
    background: rgba(255,255,255,0.9);
  }
  #lifu-cursor.lifu-cursor-text::after {
    border-radius: 1.5px;
    border-width: 0;
    box-shadow: none;
  }

  /* 点击状态 */
  #lifu-cursor.lifu-cursor-click {
    width: 14px; height: 14px;
  }
  #lifu-cursor.lifu-cursor-click::before {
    inset: 4px;
    background: rgba(255,255,255,1);
  }
  #lifu-cursor.lifu-cursor-click::after {
    box-shadow: 0 0 12px rgba(var(--lifu-cursor-accent, 212,168,83), 0.7);
  }

  /* 拖尾 */
  #lifu-cursor-trail {
    position: fixed;
    top: 0; left: 0;
    width: 6px; height: 6px;
    pointer-events: none;
    z-index: 9999;
    border-radius: 50%;
    background: rgba(var(--lifu-cursor-accent, 212,168,83), 0.5);
    box-shadow: 0 0 6px rgba(var(--lifu-cursor-accent, 212,168,83), 0.4);
    transform: translate(-50%, -50%);
    transition: background 0.8s cubic-bezier(0.45, 0, 0.55, 1);
    will-change: transform;
  }

  /* 光标光环（hover 时外扩） */
  #lifu-cursor-ring {
    position: fixed;
    top: 0; left: 0;
    width: 0; height: 0;
    pointer-events: none;
    z-index: 9998;
    border-radius: 50%;
    border: 1px solid rgba(var(--lifu-cursor-accent, 212,168,83), 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),
                height 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),
                opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),
                border-color 0.8s cubic-bezier(0.45, 0, 0.55, 1);
    opacity: 0;
  }
  #lifu-cursor-ring.active {
    width: 50px; height: 50px;
    opacity: 1;
    animation: cursorRingPulse 2s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }
  @keyframes cursorRingPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.15; }
  }

  /* 双模式颜色 */
  :root { --lifu-cursor-accent: 212, 168, 83; }
  .dark { --lifu-cursor-accent: 126, 174, 228; }

  /* 手机上隐藏自定义光标 */
  @media (max-width: 768px), (hover: none), (pointer: coarse) {
    html.custom-cursor,
    html.custom-cursor * {
      cursor: auto !important;
    }
    #lifu-cursor, #lifu-cursor-trail, #lifu-cursor-ring { display: none !important; }
  }
</style>

<div aria-hidden="true">
  <div id="lifu-cursor"></div>
  <div id="lifu-cursor-trail"></div>
  <div id="lifu-cursor-ring"></div>
</div>

<script is:inline>
  (function() {
    if (window.matchMedia('(pointer: coarse)').matches || window.matchMedia('(hover: none)').matches) return;
    if (localStorage.getItem('cursor-disabled')) return;

    document.addEventListener('astro:after-swap', init);
    document.addEventListener('swup:contentReplaced', init);
    init();

    function init() {
      document.documentElement.classList.add('custom-cursor');

      var cursor = document.getElementById('lifu-cursor');
      var trail = document.getElementById('lifu-cursor-trail');
      var ring = document.getElementById('lifu-cursor-ring');
      if (!cursor) return;

      var mouseX = 0, mouseY = 0;
      var cursorX = 0, cursorY = 0;
      var trailX = 0, trailY = 0;

      function onMouseMove(e) { mouseX = e.clientX; mouseY = e.clientY; }
      document.addEventListener('mousemove', onMouseMove, { passive: true });

      function onMouseDown() { cursor.classList.add('lifu-cursor-click'); }
      function onMouseUp() { cursor.classList.remove('lifu-cursor-click'); }
      document.addEventListener('mousedown', onMouseDown);
      document.addEventListener('mouseup', onMouseUp);

      // Detect hover/text targets
      function updateTarget(e) {
        var el = document.elementFromPoint(e.clientX, e.clientY);
        if (!el) return;
        var tag = el.tagName.toLowerCase();
        var isLink = el.closest('a, button, [role="button"], [data-cursor="pointer"]');
        var isText = tag === 'input' || tag === 'textarea' || el.closest('[data-cursor="text"]') ||
                     (tag === 'p' || tag === 'h1' || tag === 'h2' || tag === 'h3' || tag === 'h4' || tag === 'h5' || tag === 'h6' || tag === 'span' || tag === 'li' || tag === 'td' || tag === 'th' || tag === 'label');

        if (isLink) { cursor.classList.add('lifu-cursor-hover'); ring.classList.add('active'); }
        else { cursor.classList.remove('lifu-cursor-hover'); ring.classList.remove('active'); }

        if (isText && !isLink) { cursor.classList.add('lifu-cursor-text'); }
        else { cursor.classList.remove('lifu-cursor-text'); }
      }
      document.addEventListener('mousemove', function(e) { updateTarget(e); }, { passive: true });

      // Animation loop
      function animate() {
        var dx = mouseX - cursorX;
        var dy = mouseY - cursorY;
        cursorX += dx * 0.15;
        cursorY += dy * 0.15;
        trailX += (mouseX - trailX) * 0.08;
        trailY += (mouseY - trailY) * 0.08;

        cursor.style.transform = 'translate(' + cursorX + 'px, ' + cursorY + 'px) translate(-50%, -50%)';
        trail.style.transform = 'translate(' + trailX + 'px, ' + trailY + 'px) translate(-50%, -50%)';
        ring.style.transform = 'translate(' + cursorX + 'px, ' + cursorY + 'px) translate(-50%, -50%)';

        requestAnimationFrame(animate);
      }
      requestAnimationFrame(animate);
    }
  })();
</script>
