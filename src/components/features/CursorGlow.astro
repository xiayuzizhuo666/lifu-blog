---
// 光标光晕效果 — 纯 CSS 变量驱动，亮色鎏金 / 暗色银蓝
// 仅桌面端启用，pointer-events: none 永不干扰交互
---

<style is:global>
  #lifu-cursor-glow {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    will-change: left, top;
    background: radial-gradient(circle at center,
      rgba(var(--gate-accent-rgb, 212,168,83), 0.12) 0%,
      rgba(var(--gate-accent-rgb, 212,168,83), 0.04) 35%,
      transparent 70%
    );
    opacity: 1;
    transition: opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* 暗色下提亮 */
  :root.dark #lifu-cursor-glow {
    background: radial-gradient(circle at center,
      rgba(var(--gate-accent-rgb, 126,174,228), 0.10) 0%,
      rgba(var(--gate-accent-rgb, 126,174,228), 0.03) 35%,
      transparent 70%
    );
  }

  /* 悬停在可点击元素上时增强光晕 */
  #lifu-cursor-glow.hovering {
    width: 280px;
    height: 280px;
    background: radial-gradient(circle at center,
      rgba(var(--gate-accent-rgb, 212,168,83), 0.18) 0%,
      rgba(var(--gate-accent-rgb, 212,168,83), 0.06) 40%,
      transparent 70%
    );
  }
  :root.dark #lifu-cursor-glow.hovering {
    background: radial-gradient(circle at center,
      rgba(var(--gate-accent-rgb, 126,174,228), 0.14) 0%,
      rgba(var(--gate-accent-rgb, 126,174,228), 0.05) 40%,
      transparent 70%
    );
  }

  /* 隐藏条件：触摸设备 / 移动端 / 极窄屏 */
  @media (hover: none) and (pointer: coarse) {
    #lifu-cursor-glow { display: none !important; }
  }
  @media (max-width: 768px) {
    #lifu-cursor-glow { display: none !important; }
  }
  /* 用户系统开启了减少动画则隐藏 */
  @media (prefers-reduced-motion: reduce) {
    #lifu-cursor-glow { display: none !important; }
  }
</style>

<div id="lifu-cursor-glow" aria-hidden="true"></div>

<script is:inline>
  (function() {
    var glow = document.getElementById('lifu-cursor-glow');
    if (!glow) return;

    var mx = -1000, my = -1000;   // target position
    var cx = -1000, cy = -1000;   // current (lerped) position
    var raf = null;
    var visible = false;

    function lerp(a, b, t) { return a + (b - a) * t; }

    function tick() {
      cx = lerp(cx, mx, 0.08);
      cy = lerp(cy, my, 0.08);

      if (Math.abs(cx - mx) > 0.05 || Math.abs(cy - my) > 0.05) {
        glow.style.left = cx + 'px';
        glow.style.top = cy + 'px';
        raf = requestAnimationFrame(tick);
      } else {
        cx = mx; cy = my;
        glow.style.left = mx + 'px';
        glow.style.top = my + 'px';
        raf = null;
      }
    }

    function startTick() {
      if (raf) return;
      raf = requestAnimationFrame(tick);
    }

    document.addEventListener('mousemove', function(e) {
      if (!visible) {
        visible = true;
        glow.style.opacity = '1';
        cx = e.clientX; cy = e.clientY;
        glow.style.left = cx + 'px';
        glow.style.top = cy + 'px';
      }
      mx = e.clientX; my = e.clientY;
      startTick();
    }, { passive: true });

    document.addEventListener('mouseleave', function() {
      visible = false;
      glow.style.opacity = '0';
    });

    // Hover detection: glow expands on links/buttons/interactive elements
    var hovering = false;
    var hoverSelector = 'a, button, input, textarea, select, [role="button"], [tabindex]:not([tabindex="-1"]), .clickable, [data-bgm-toggle]';

    document.addEventListener('mouseover', function(e) {
      if (e.target) {
        try {
          var el = e.target.closest(hoverSelector);
          if (el) {
            hovering = true;
            glow.classList.add('hovering');
          } else {
            if (hovering) { hovering = false; glow.classList.remove('hovering'); }
          }
        } catch (_) {}
      }
    }, { passive: true });

    // Cleanup on Astro page transitions
    document.addEventListener('astro:before-swap', function() {
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      if (glow) { glow.style.opacity = '0'; }
    });
  })();
</script>
